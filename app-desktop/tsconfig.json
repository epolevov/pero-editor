{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@/*": ["./electron/*"]
    }
  },
  "include": ["electron/**/*.ts", "vite.*.config.ts"],
  "exclude": ["node_modules", "dist", "dist-electron"]
}
