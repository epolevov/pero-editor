# Database (SQLite)
DATABASE_URL="file:./dev.db"

# Moleculer
MOLECULER_NAMESPACE="text-assistant"
NODE_ENV="development"
LOG_LEVEL="info"

# Transporter: TCP for local, NATS/Redis for production
# TRANSPORTER=TCP
# TRANSPORTER=nats://localhost:4222

# Optional Redis cacher
# REDIS_URL=redis://localhost:6379

# WebSocket Gateway
WS_PORT=8080

# OpenRouter (server-side only)
OPENROUTER_TIMEOUT_MS=20000
OPENROUTER_MAX_RETRIES=2
# Required for storing UI-provided OpenRouter keys in DB (32-byte key: hex/base64/utf8)
AI_SECRETS_ENCRYPTION_KEY="your_32_byte_encryption_key_here"
# Optional headers for OpenRouter analytics/ranking
# OPENROUTER_HTTP_REFERER="https://your-domain-or-app-url"
# OPENROUTER_X_TITLE="Pero Editor Backend"
